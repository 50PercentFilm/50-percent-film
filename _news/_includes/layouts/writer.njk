<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{{ name }} — 50% Film</title>
<link rel="icon" type="image/x-icon" href="/favicon.ico">
<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
{% if bio %}<meta name="description" content="{{ bio }}">{% endif %}
<meta property="og:type" content="profile">
<meta property="og:site_name" content="50% Film">
<meta property="og:title" content="{{ name }} — 50% Film">
{% if bio %}<meta property="og:description" content="{{ bio }}">{% endif %}
<meta property="og:url" content="https://50percentfilm.com{{ page.url }}">
{% if photo %}<meta property="og:image" content="https://50percentfilm.com{{ photo }}">{% else %}<meta property="og:image" content="https://50percentfilm.com/og-image.jpg">{% endif %}
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content="{{ name }} — 50% Film">
{% if bio %}<meta name="twitter:description" content="{{ bio }}">{% endif %}
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Serif+Display:ital@0;1&family=Space+Mono:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet">
<style>
*, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
:root { --black: #0a0a0a; --white: #f0ece4; --cream: #e8e2d6; --red: #c8341a; --mid: #888; }
html { scroll-behavior: smooth; }
body { background: var(--black); color: var(--white); font-family: 'Space Mono', monospace; cursor: none; overflow-x: hidden; }
.cursor { position: fixed; width: 10px; height: 10px; background: var(--red); border-radius: 50%; pointer-events: none; z-index: 9999; transform: translate(-50%, -50%); transition: width 0.2s, height 0.2s; mix-blend-mode: difference; }
.cursor.big { width: 40px; height: 40px; }
body::before { content: ''; position: fixed; inset: 0; background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.04'/%3E%3C/svg%3E"); pointer-events: none; z-index: 9998; opacity: 0.35; }
nav { position: fixed; top: 0; left: 0; right: 0; z-index: 100; display: flex; justify-content: space-between; align-items: center; padding: 28px 40px; background: linear-gradient(to bottom, rgba(10,10,10,0.95) 0%, transparent 100%); }
.nav-logo { font-family: 'Bebas Neue', sans-serif; font-size: 22px; letter-spacing: 0.15em; color: var(--white); text-decoration: none; }
.nav-back { font-size: 10px; letter-spacing: 0.2em; text-transform: uppercase; color: var(--mid); text-decoration: none; display: flex; align-items: center; gap: 10px; transition: color 0.2s; }
.nav-back:hover { color: var(--white); }
.nav-back::before { content: '←'; }
.wrap { max-width: 900px; margin: 0 auto; padding: 160px 40px 120px; }
.profile-eyebrow { font-size: 10px; letter-spacing: 0.3em; text-transform: uppercase; color: var(--red); margin-bottom: 28px; opacity: 0; animation: fadeUp 0.8s 0.2s forwards; }
.profile-head { display: flex; gap: 48px; align-items: flex-start; margin-bottom: 56px; opacity: 0; animation: fadeUp 0.8s 0.35s forwards; }
.profile-photo { flex-shrink: 0; width: 180px; height: 180px; object-fit: cover; border: 1px solid #1a1a1a; filter: grayscale(1) contrast(1.05); }
.profile-photo-empty { flex-shrink: 0; width: 180px; height: 180px; border: 1px solid #1a1a1a; background: #0d0d0d; display: flex; align-items: center; justify-content: center; }
.profile-photo-empty span { font-family: 'Bebas Neue', sans-serif; font-size: 64px; color: #1f1f1f; }
.profile-head-text { flex: 1; }
.profile-name { font-family: 'Bebas Neue', sans-serif; font-size: clamp(52px, 8vw, 96px); line-height: 0.9; color: var(--white); margin-bottom: 16px; }
.profile-role { font-size: 10px; letter-spacing: 0.25em; text-transform: uppercase; color: var(--red); margin-bottom: 24px; }
.profile-bio { font-size: 13px; line-height: 2; color: var(--mid); max-width: 560px; }
.profile-bio em { font-style: italic; font-family: 'DM Serif Display', serif; opacity: 0.85; }
.profile-links { display: flex; flex-wrap: wrap; gap: 10px; margin-top: 28px; }
.profile-link { font-size: 9px; letter-spacing: 0.2em; text-transform: uppercase; color: var(--mid); text-decoration: none; border: 1px solid #1a1a1a; padding: 9px 16px; transition: color 0.2s, border-color 0.2s; }
.profile-link:hover { color: var(--white); border-color: var(--red); }
.profile-body { max-width: 640px; margin-bottom: 72px; opacity: 0; animation: fadeUp 0.8s 0.5s forwards; }
.profile-body p { font-size: 13px; line-height: 2.1; color: #bbb; margin-bottom: 24px; }
.profile-body em { font-style: italic; font-family: 'DM Serif Display', serif; opacity: 0.9; }
.profile-body strong { color: var(--white); }
.profile-body a { color: var(--red); text-decoration: none; border-bottom: 1px solid rgba(200,52,26,0.4); }
.pieces-label { font-size: 8px; letter-spacing: 0.35em; text-transform: uppercase; color: var(--red); margin-bottom: 8px; display: block; }
.pieces-heading { font-family: 'Bebas Neue', sans-serif; font-size: 40px; line-height: 1; color: var(--white); margin-bottom: 36px; padding-bottom: 24px; border-bottom: 1px solid #1a1a1a; }
.piece-row { display: block; text-decoration: none; color: inherit; padding: 28px 0; border-bottom: 1px solid #1a1a1a; transition: padding-left 0.25s; }
.piece-row:hover { padding-left: 12px; }
.piece-row-kicker { display: flex; align-items: center; gap: 14px; margin-bottom: 14px; }
.piece-row-cat { font-size: 8px; letter-spacing: 0.3em; text-transform: uppercase; color: var(--white); background: var(--red); padding: 4px 10px; }
.piece-row-date { font-size: 8px; letter-spacing: 0.2em; text-transform: uppercase; color: #444; }
.piece-row-title { font-family: 'Bebas Neue', sans-serif; font-size: clamp(26px, 3.5vw, 40px); line-height: 0.98; color: var(--white); display: flex; justify-content: space-between; align-items: baseline; gap: 20px; transition: color 0.2s; }
.piece-row:hover .piece-row-title { color: var(--cream); }
.piece-row-title em { font-family: 'DM Serif Display', serif; font-style: italic; color: var(--cream); opacity: 0.65; }
.piece-row-arrow { flex-shrink: 0; color: var(--mid); font-size: 20px; transition: transform 0.25s, color 0.2s; }
.piece-row:hover .piece-row-arrow { color: var(--red); transform: translateX(4px); }
.pieces-empty { font-size: 12px; line-height: 2; color: #444; }
.back-foot { display: inline-flex; align-items: center; gap: 10px; margin-top: 64px; font-size: 10px; letter-spacing: 0.2em; text-transform: uppercase; color: var(--mid); text-decoration: none; transition: color 0.2s; }
.back-foot::before { content: '←'; }
.back-foot:hover { color: var(--white); }
footer { border-top: 1px solid #1a1a1a; padding: 48px 40px; display: flex; justify-content: space-between; align-items: center; }
.footer-logo { font-family: 'Bebas Neue', sans-serif; font-size: 18px; letter-spacing: 0.15em; }
.footer-copy { font-size: 9px; letter-spacing: 0.15em; color: var(--mid); text-transform: uppercase; }
.footer-links { display: flex; gap: 32px; list-style: none; }
.footer-links a { font-size: 9px; letter-spacing: 0.2em; text-transform: uppercase; color: var(--mid); text-decoration: none; transition: color 0.2s; }
.footer-links a:hover { color: var(--white); }
@keyframes fadeUp { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }
@media (max-width: 700px) {
nav { padding: 20px 24px; }
.wrap { padding: 120px 24px 80px; }
.profile-head { flex-direction: column; gap: 28px; }
.profile-photo, .profile-photo-empty { width: 120px; height: 120px; }
footer { flex-direction: column; gap: 24px; text-align: center; }
.footer-links { flex-wrap: wrap; justify-content: center; }
}
</style>
</head>
<body>
<div class="cursor" id="cursor"></div>

<nav>
<a href="/" class="nav-logo">50% Film</a>
<a href="/news/" class="nav-back">Back to News</a>
</nav>

<main class="wrap">
<p class="profile-eyebrow">Writer</p>

<div class="profile-head">
{% if photo %}<img class="profile-photo" src="{{ photo }}" alt="{{ name }}" loading="lazy">{% else %}<div class="profile-photo-empty"><span>{{ name | truncate(1, true, "") }}</span></div>{% endif %}
<div class="profile-head-text">
<h1 class="profile-name">{{ name }}</h1>
{% if role %}<p class="profile-role">{{ role }}</p>{% endif %}
{% if bio %}<p class="profile-bio">{{ bio }}</p>{% endif %}
<div class="profile-links">
{% if links %}{% for link in links %}<a class="profile-link" href="{{ link.url }}" {% if 'mailto:' not in link.url %}target="_blank" rel="noopener"{% endif %}>{{ link.label }}</a>{% endfor %}{% endif %}
</div>
</div>
</div>

{% if content %}<div class="profile-body">{{ content | safe }}</div>{% endif %}

<span class="pieces-label">Selected writing</span>
<h2 class="pieces-heading">Pieces by {{ name }}</h2>
{%- set mine = collections.news | byAuthor(name) -%}
{%- if mine.length -%}
{%- for post in mine -%}
<a class="piece-row" href="{{ post.url }}">
<div class="piece-row-kicker">
<span class="piece-row-cat">{{ post.data.category }}</span>
<span class="piece-row-date">{{ post.data.date | monthYear }}</span>
</div>
<div class="piece-row-title">
<span>{{ post.data.title }}{% if post.data.title_accent %} <em>{{ post.data.title_accent }}</em>{% endif %}</span>
<span class="piece-row-arrow" aria-hidden="true">→</span>
</div>
</a>
{%- endfor -%}
{%- else -%}
<p class="pieces-empty">No published pieces yet.</p>
{%- endif -%}

<a class="back-foot" href="/news/">Back to News</a>
</main>

<footer>
<span class="footer-logo">50% Film</span>
<span class="footer-copy">© 2025–2026 — Short Cinema Label — London, UK</span>
<ul class="footer-links">
<li><a href="https://www.instagram.com/50percentfilm/" target="_blank" rel="noopener">Instagram</a></li>
<li><a href="https://boxd.it/lHBGz" target="_blank" rel="noopener">Letterboxd</a></li>
<li><a href="/#newsletter">Newsletter</a></li>
<li><a href="/contact.html">Contact</a></li>
</ul>
</footer>

<script>
(function () {
var cursor = document.getElementById('cursor');
if (cursor && window.matchMedia('(hover: hover) and (pointer: fine)').matches) {
window.addEventListener('mousemove', function (e) { cursor.style.left = e.clientX + 'px'; cursor.style.top = e.clientY + 'px'; });
document.querySelectorAll('a, button').forEach(function (el) {
el.addEventListener('mouseenter', function () { cursor.classList.add('big'); });
el.addEventListener('mouseleave', function () { cursor.classList.remove('big'); });
});
} else if (cursor) { cursor.style.display = 'none'; document.body.style.cursor = 'auto'; }
})();
</script>
</body>
</html>
