---
layout: layouts/base.njk
permalink: /news/index.html
title: News & Reviews
standfirst: Reviews, essays and notes on short cinema from 50% Film.
---
<section class="news-index">
  <a class="back" href="/">← Back to Home</a>

  <p class="eyebrow">{{ site.tagline }}</p>
  <h1 class="page-title">News &amp; <em>Reviews.</em></h1>
  <p class="count">{{ collections.news | length }} pieces published</p>
  <p class="blurb">
    Festival coverage, filmmaker interviews, industry news, and critical writing on
    the short form. More pieces added regularly.
  </p>

  <ul class="piece-list">
    {% for post in collections.news %}
    <li class="piece-card">
      <a href="{{ post.url }}">
        <p class="eyebrow">
          <span class="cat">{{ post.data.category }}</span>
          <span class="sep">✦</span>
          <time datetime="{{ post.data.date }}">{{ post.data.date | monthYear }}</time>
        </p>
        <h2 class="card-title">
          {{ post.data.title }}{% if post.data.title_accent %} <em>{{ post.data.title_accent }}</em>{% endif %}
        </h2>
        {% if post.data.standfirst %}<p class="card-standfirst">{{ post.data.standfirst }}</p>{% endif %}
        <span class="read">Read →</span>
      </a>
    </li>
    {% endfor %}
  </ul>
</section>
