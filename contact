<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Contact — 50% Film</title>
<link rel="icon" type="image/x-icon" href="favicon.ico">
<link rel="icon" type="image/png" sizes="16x16" href="favicon-16x16.png">
<link rel="icon" type="image/png" sizes="32x32" href="favicon-32x32.png">
<link rel="icon" type="image/png" sizes="512x512" href="favicon-512x512.png">
<link rel="apple-touch-icon" sizes="180x180" href="apple-touch-icon.png">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Serif+Display:ital@0;1&family=Space+Mono:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

  :root {
    --black: #0a0a0a;
    --white: #f0ece4;
    --cream: #e8e2d6;
    --red: #c8341a;
    --gray: #2a2a2a;
    --mid: #888;
  }

  html { scroll-behavior: smooth; }

  body {
    background: var(--black);
    color: var(--white);
    font-family: 'Space Mono', monospace;
    cursor: none;
    overflow-x: hidden;
  }

  .cursor {
    position: fixed;
    width: 10px;
    height: 10px;
    background: var(--red);
    border-radius: 50%;
    pointer-events: none;
    z-index: 9999;
    transform: translate(-50%, -50%);
    transition: transform 0.1s, width 0.2s, height 0.2s;
    mix-blend-mode: difference;
  }
  .cursor.big { width: 40px; height: 40px; }

  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.04'/%3E%3C/svg%3E");
    pointer-events: none;
    z-index: 9998;
    opacity: 0.35;
  }

  /* NAV */
  nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    padding: 28px 40px;
    mix-blend-mode: difference;
  }

  .nav-logo {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 22px;
    letter-spacing: 0.15em;
    color: var(--white);
    text-decoration: none;
  }

  /* Menu toggle button */
  .menu-toggle {
    display: flex;
    align-items: center;
    gap: 12px;
    background: none;
    border: none;
    cursor: none;
    padding: 0;
    z-index: 101;
    color: var(--white);
  }

  .menu-toggle-label {
    font-family: 'Space Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--white);
  }

  .menu-toggle-bars {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 26px;
    height: 18px;
  }

  .menu-toggle-bars span {
    display: block;
    width: 100%;
    height: 2px;
    background: var(--white);
    transition: transform 0.3s, opacity 0.3s;
  }

  .menu-toggle.open .menu-toggle-bars span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .menu-toggle.open .menu-toggle-bars span:nth-child(2) { opacity: 0; }
  .menu-toggle.open .menu-toggle-bars span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

  /* Dropdown menu panel */
  .nav-dropdown {
    position: fixed;
    top: 0;
    right: 0;
    width: min(420px, 100%);
    height: 100vh;
    background: var(--black);
    border-left: 1px solid #1a1a1a;
    z-index: 99;
    transform: translateX(100%);
    transition: transform 0.45s cubic-bezier(0.65, 0, 0.35, 1);
    overflow-y: auto;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 100px 48px;
  }

  .nav-dropdown.open {
    transform: translateX(0);
  }

  .nav-dropdown-eyebrow {
    font-size: 9px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--red);
    margin-bottom: 20px;
  }

  .nav-dropdown-list {
    list-style: none;
    border-top: 1px solid #1a1a1a;
  }

  .nav-dropdown-list li {
    border-bottom: 1px solid #1a1a1a;
  }

  .nav-dropdown-list a {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 22px 0;
    font-family: 'DM Serif Display', serif;
    font-style: italic;
    font-size: 26px;
    color: var(--white);
    text-decoration: none;
    transition: padding-left 0.3s, color 0.3s;
  }

  .nav-dropdown-list a:hover {
    color: var(--red);
    padding-left: 12px;
  }

  .nav-dropdown-list a.current {
    color: var(--red);
  }

  .nav-dropdown-list a .nav-dropdown-num {
    font-family: 'Space Mono', monospace;
    font-style: normal;
    font-size: 10px;
    letter-spacing: 0.2em;
    color: var(--mid);
    transition: color 0.3s;
  }

  .nav-dropdown-list a:hover .nav-dropdown-num,
  .nav-dropdown-list a.current .nav-dropdown-num {
    color: var(--red);
  }

  .nav-dropdown-footer {
    margin-top: 48px;
    display: flex;
    gap: 28px;
    flex-wrap: wrap;
  }

  .nav-dropdown-footer a {
    font-size: 9px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--mid);
    text-decoration: none;
    transition: color 0.2s;
  }
  .nav-dropdown-footer a:hover { color: var(--white); }

  /* Dimmed backdrop */
  .nav-backdrop {
    position: fixed;
    inset: 0;
    background: rgba(10,10,10,0.6);
    backdrop-filter: blur(2px);
    z-index: 98;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.4s;
  }
  .nav-backdrop.open {
    opacity: 1;
    pointer-events: auto;
  }

  @media (max-width: 600px) {
    .nav-dropdown { padding: 100px 28px; width: 100%; }
    .nav-dropdown-list a { font-size: 22px; }
    .menu-toggle-label { display: none; }
  }

  /* PAGE HEAD — mirror booth */
  .page-head {
    min-height: 75vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    text-align: center;
    padding: 160px 40px 80px;
    position: relative;
    overflow: hidden;
  }

  /* Spotlight glow behind the title */
  .page-head::before {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    width: 70vw;
    height: 70vw;
    transform: translate(-50%, -55%);
    background: radial-gradient(circle, rgba(200,52,26,0.10) 0%, transparent 65%);
    pointer-events: none;
    z-index: 0;
  }

  .page-eyebrow {
    font-size: 10px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--red);
    margin-bottom: 24px;
    opacity: 0;
    animation: fadeUp 0.8s 0.2s forwards;
    position: relative;
    z-index: 1;
  }

  .page-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(72px, 13vw, 180px);
    line-height: 0.9;
    letter-spacing: -0.01em;
    color: var(--white);
    opacity: 0;
    animation: fadeUp 0.8s 0.4s forwards;
    position: relative;
    z-index: 1;
  }

  .page-title em {
    font-family: 'DM Serif Display', serif;
    font-style: italic;
    color: var(--mid);
  }

  /* The "you talkin to me" line */
  .mirror-line {
    margin-top: 28px;
    font-family: 'DM Serif Display', serif;
    font-style: italic;
    font-size: clamp(20px, 3.5vw, 36px);
    color: var(--cream);
    opacity: 0;
    animation: fadeUp 0.8s 0.6s forwards;
    position: relative;
    z-index: 1;
  }

  .mirror-line::before,
  .mirror-line::after {
    content: '—';
    color: var(--red);
    margin: 0 12px;
    font-family: 'Space Mono', monospace;
    font-style: normal;
    opacity: 0.5;
  }

  .mirror-sub {
    margin-top: 24px;
    font-size: 11px;
    line-height: 1.9;
    color: var(--mid);
    max-width: 480px;
    opacity: 0;
    animation: fadeUp 0.8s 0.8s forwards;
    position: relative;
    z-index: 1;
  }

  /* SLATE / CLAPPERBOARD INTRO STRIP */
  .slate-strip {
    border-top: 1px solid #1a1a1a;
    border-bottom: 1px solid #1a1a1a;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
  }

  .slate-cell {
    padding: 28px 32px;
    border-right: 1px solid #1a1a1a;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .slate-cell:last-child { border-right: none; }

  .slate-label {
    font-size: 8px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--red);
  }

  .slate-value {
    font-family: 'DM Serif Display', serif;
    font-style: italic;
    font-size: 18px;
    color: var(--white);
    line-height: 1.3;
  }

  @media (max-width: 768px) {
    .slate-strip { grid-template-columns: 1fr 1fr; }
    .slate-cell { padding: 24px; border-bottom: 1px solid #1a1a1a; }
    .slate-cell:nth-child(2) { border-right: none; }
    .slate-cell:nth-child(4) { border-right: none; border-bottom: none; }
    .slate-cell:nth-child(3) { border-bottom: none; }
  }

  /* CONTACT SECTION */
  .contact {
    padding: 120px 40px;
    border-bottom: 1px solid #1a1a1a;
  }

  .section-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 64px;
    border-bottom: 1px solid #1e1e1e;
    padding-bottom: 24px;
  }

  .section-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(40px, 5vw, 72px);
    letter-spacing: 0.02em;
    line-height: 1;
  }

  .section-title em {
    font-family: 'DM Serif Display', serif;
    font-style: italic;
    color: var(--mid);
  }

  .section-count {
    font-size: 9px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--mid);
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: 80px;
  }

  .contact-p {
    font-size: 12px;
    line-height: 2;
    color: var(--mid);
    margin-bottom: 24px;
    max-width: 440px;
  }

  .contact-email {
    color: var(--white);
    text-decoration: underline;
    text-decoration-color: var(--red);
    text-underline-offset: 4px;
    transition: color 0.2s;
  }
  .contact-email:hover { color: var(--red); }

  .contact-fact {
    margin-top: 48px;
    border: 1px solid #1e1e1e;
    padding: 28px;
    background: #0f0f0f;
    max-width: 440px;
  }

  .contact-fact-label {
    font-size: 9px;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--red);
    margin-bottom: 12px;
  }

  .contact-fact-value {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 28px;
    color: var(--white);
  }

  .contact-fact-note {
    display: block;
    font-family: 'Space Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.05em;
    text-transform: none;
    color: var(--mid);
    margin-top: 8px;
    line-height: 1.6;
  }

  /* Credits-style sign-off list */
  .contact-credits {
    margin-top: 32px;
    border-top: 1px solid #1e1e1e;
    padding-top: 24px;
  }

  .contact-credits-row {
    display: flex;
    justify-content: space-between;
    gap: 16px;
    font-size: 10px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--mid);
    padding: 10px 0;
    border-bottom: 1px solid #161616;
  }
  .contact-credits-row:last-child { border-bottom: none; }

  .contact-credits-row span:last-child {
    color: var(--white);
    text-transform: none;
    letter-spacing: 0.05em;
    text-align: right;
  }

  /* CONTACT FORM */
  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .form-group label {
    font-size: 9px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--red);
  }

  .form-group input,
  .form-group textarea {
    background: #111;
    border: 1px solid #2a2a2a;
    color: var(--white);
    font-family: 'Space Mono', monospace;
    font-size: 13px;
    padding: 16px 18px;
    transition: border-color 0.2s, background 0.2s;
    resize: vertical;
  }

  .form-group input::placeholder,
  .form-group textarea::placeholder {
    color: #555;
  }

  .form-group input:focus,
  .form-group textarea:focus {
    outline: none;
    border-color: var(--red);
    background: #141414;
  }

  .form-submit {
    font-family: 'Space Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--black);
    background: var(--white);
    border: none;
    padding: 18px 36px;
    cursor: none;
    transition: background 0.2s, color 0.2s;
    align-self: flex-start;
  }
  .form-submit:hover { background: var(--red); color: var(--white); }
  .form-submit:disabled { opacity: 0.6; cursor: none; }

  .form-note {
    font-size: 10px;
    letter-spacing: 0.1em;
    color: var(--mid);
    min-height: 1.5em;
  }
  .form-note.success { color: var(--red); }

  @media (max-width: 768px) {
    .contact { padding: 80px 24px; }
    .contact-grid { grid-template-columns: 1fr; gap: 48px; }
  }

  /* TICKER */
  .ticker {
    border-top: 1px solid #222;
    border-bottom: 1px solid #222;
    overflow: hidden;
    padding: 12px 0;
    background: var(--black);
  }
  .ticker-track {
    display: flex;
    gap: 60px;
    animation: ticker 24s linear infinite;
    white-space: nowrap;
  }
  .ticker-item {
    font-size: 9px;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--mid);
    flex-shrink: 0;
  }
  .ticker-item span { color: var(--red); margin-right: 10px; }
  @keyframes ticker {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }

  /* FOOTER */
  footer {
    border-top: 1px solid #1a1a1a;
    padding: 48px 40px;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .footer-logo { font-family: 'Bebas Neue', sans-serif; font-size: 18px; letter-spacing: 0.15em; }
  .footer-copy { font-size: 9px; letter-spacing: 0.15em; color: var(--mid); text-transform: uppercase; }
  .footer-links { display: flex; gap: 32px; list-style: none; }
  .footer-links a { font-size: 9px; letter-spacing: 0.2em; text-transform: uppercase; color: var(--mid); text-decoration: none; transition: color 0.2s; }
  .footer-links a:hover { color: var(--white); }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(24px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .reveal {
    opacity: 0;
    transform: translateY(32px);
    transition: opacity 0.7s, transform 0.7s;
  }
  .reveal.visible { opacity: 1; transform: translateY(0); }

  @media (max-width: 768px) {
    nav { padding: 20px 24px; mix-blend-mode: normal; }
    .page-head { padding: 120px 24px 60px; min-height: 65vh; }
    footer { flex-direction: column; gap: 24px; text-align: center; }
    .footer-links { flex-wrap: wrap; justify-content: center; }
  }
</style>
</head>
