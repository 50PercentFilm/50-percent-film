<!-- CONTACT -->
<section class="contact" id="contact">
  <div class="section-header reveal">
    <h2 class="section-title">Get In <em>Touch</em></h2>
    <span class="section-count">No agents required</span>
  </div>
  <div class="contact-grid">
    <div class="contact-left reveal">
      <p class="contact-p">Got a question, a tip, a film you think we should see, or feedback on how long we took to reply to your last email? This is the place. We're two people running this in our spare time, so please be patient — but we promise a real human (one of us) will read it, popcorn in hand.</p>
      <p class="contact-p">Prefer to skip the form and go straight to the source? Email us directly at <a href="mailto:50percentfilm@gmail.com" class="contact-email">50percentfilm@gmail.com</a>.</p>
      <div class="contact-fact">
        <div class="contact-fact-label">Average reply time</div>
        <div class="contact-fact-value">2–5 business days<span class="contact-fact-note">(longer if it's a good film — we'll be busy watching it twice)</span></div>
      </div>
      <div class="contact-credits">
        <div class="contact-credits-row"><span>Submissions &amp; films</span><span>50percentfilm@gmail.com</span></div>
        <div class="contact-credits-row"><span>Partnerships</span><span>50percentfilm@gmail.com</span></div>
        <div class="contact-credits-row"><span>Everything else</span><span>50percentfilm@gmail.com</span></div>
        <div class="contact-credits-row"><span>Compliments</span><span>Always welcome</span></div>
      </div>
    </div>
    <form class="contact-form reveal" id="contactForm" action="https://formspree.io/f/mnjykljy" method="POST">
      <div class="form-group">
        <label for="name">Name</label>
        <input type="text" id="name" name="name" required placeholder="Your name (or your director alias)">
      </div>
      <div class="form-group">
        <label for="subject">Subject</label>
        <input type="text" id="subject" name="subject" required placeholder="What's this about?">
      </div>
      <div class="form-group">
        <label for="message">Your Message</label>
        <textarea id="message" name="message" rows="6" required placeholder="Tell us everything. We have time. Probably."></textarea>
      </div>
      <input type="hidden" name="_subject" value="New message from 50% Film website">
      <button type="submit" class="form-submit">Send Message →</button>
      <p class="form-note" id="formNote"></p>
    </form>
  </div>
</section>

