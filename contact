<!-- PAGE HEAD -->
<section class="page-head">
  <p class="page-eyebrow">Take 1 — Action</p>
  <h1 class="page-title">Contact<br><em>Us.</em></h1>
  <p class="mirror-line">You talkin' to us?</p>
  <p class="mirror-sub">Good. We're the only ones here. Whether you've got a film, a question, a correction about our spelling of "Letterboxd," or you just want to tell us our cursor is annoying — this is the place.</p>
</section>

<!-- SLATE STRIP -->
<div class="slate-strip">
  <div class="slate-cell reveal">
    <div class="slate-label">Production</div>
    <div class="slate-value">50% Film</div>
  </div>
  <div class="slate-cell reveal">
    <div class="slate-label">Scene</div>
    <div class="slate-value">You, Reading This</div>
  </div>
  <div class="slate-cell reveal">
    <div class="slate-label">Take</div>
    <div class="slate-value">Probably Your First</div>
  </div>
  <div class="slate-cell reveal">
    <div class="slate-label">Director</div>
    <div class="slate-value">Pending Reply</div>
  </div>
